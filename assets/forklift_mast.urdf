<?xml version="1.0" encoding="UTF-8"?>
<!--
  forklift_mast.urdf
  Industrial forklift mast assembly for Husky UGV
  Kinematic chain: base_link > carriage_link > fork_link > magnet_link
  Joint order must be preserved — Python code references joints/links by index.
    LIFT_JOINT  = 0  (lift_joint,   prismatic)
    MAGNET_LINK = 2  (magnet_link,  child of magnet_joint)
-->
<robot name="forklift_mast">

  <!-- ================================================================
       BASE  —  twin I-beam mast rails with top and mid crossbars
       ================================================================ -->
  <link name="base_link">

    <!-- left rail -->
    <visual>
      <origin xyz="0 -0.15 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.8"/></geometry>
      <material name="mast_steel"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>

    <!-- right rail -->
    <visual>
      <origin xyz="0 0.15 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.8"/></geometry>
      <material name="mast_steel"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>

    <!-- top crossbar -->
    <visual>
      <origin xyz="0 0 0.38" rpy="0 0 0"/>
      <geometry><box size="0.06 0.36 0.06"/></geometry>
      <material name="mast_steel"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>

    <!-- mid crossbar -->
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.36 0.06"/></geometry>
      <material name="mast_steel"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>

    <!-- single collision box covering the full mast width -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.36 0.8"/></geometry>
    </collision>

    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1"    ixy="0.0" ixz="0.0"
                            iyy="0.1" iyz="0.0"
                                      izz="0.01"/>
    </inertial>
  </link>

  <!-- ================================================================
       CARRIAGE  —  load-backrest plate that rides up the mast rails
       ================================================================ -->
  <link name="carriage_link">

    <!-- backrest / load-guard plate -->
    <visual>
      <origin xyz="-0.02 0 0.12" rpy="0 0 0"/>
      <geometry><box size="0.04 0.36 0.28"/></geometry>
      <material name="carriage_yellow"><color rgba="0.95 0.78 0.0 1.0"/></material>
    </visual>

    <!-- finger bar (horizontal bar forks hang from) -->
    <visual>
      <origin xyz="-0.02 0 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.04 0.36 0.05"/></geometry>
      <material name="carriage_yellow"><color rgba="0.95 0.78 0.0 1.0"/></material>
    </visual>

    <collision>
      <origin xyz="-0.02 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.04 0.36 0.36"/></geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                           iyy="0.001" iyz="0.0"
                                       izz="0.001"/>
    </inertial>
  </link>

  <!-- lift_joint : prismatic along Z, ±0.4 m travel -->
  <joint name="lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child  link="carriage_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.4" upper="0.4" effort="2000" velocity="0.5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       FORK  —  two L-shaped tines extending forward from the carriage
                origin is 0.25 m ahead of carriage_link in X
       ================================================================ -->
  <link name="fork_link">

    <!-- left tine — horizontal blade -->
    <visual>
      <origin xyz="0.0 -0.12 0.0" rpy="0 0 0"/>
      <geometry><box size="0.42 0.06 0.025"/></geometry>
      <material name="fork_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <!-- left tine — heel (vertical back piece) -->
    <visual>
      <origin xyz="-0.19 -0.12 0.055" rpy="0 0 0"/>
      <geometry><box size="0.04 0.06 0.09"/></geometry>
      <material name="fork_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>

    <!-- right tine — horizontal blade -->
    <visual>
      <origin xyz="0.0 0.12 0.0" rpy="0 0 0"/>
      <geometry><box size="0.42 0.06 0.025"/></geometry>
      <material name="fork_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <!-- right tine — heel -->
    <visual>
      <origin xyz="-0.19 0.12 0.055" rpy="0 0 0"/>
      <geometry><box size="0.04 0.06 0.09"/></geometry>
      <material name="fork_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>

    <!-- single flat collision shape spanning both tines -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.42 0.30 0.025"/></geometry>
    </collision>

    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                           iyy="0.001" iyz="0.0"
                                       izz="0.001"/>
    </inertial>
  </link>

  <!-- fork_joint : fixed, 0.25 m forward along X from carriage -->
  <joint name="fork_joint" type="fixed">
    <parent link="carriage_link"/>
    <child  link="fork_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       MAGNET  —  electromagnet pad at fork tip (colour set at runtime)
       ================================================================ -->
  <link name="magnet_link">

    <!-- main magnet body -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.28 0.04"/></geometry>
      <material name="magnet_red"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
    <!-- indicator ring -->
    <visual>
      <origin xyz="0.031 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.04" length="0.002"/></geometry>
      <material name="magnet_ring"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.28 0.04"/></geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                            iyy="0.0001" iyz="0.0"
                                         izz="0.0001"/>
    </inertial>
  </link>

  <!-- magnet_joint : fixed, 0.25 m forward along X from fork tip -->
  <joint name="magnet_joint" type="fixed">
    <parent link="fork_link"/>
    <child  link="magnet_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>

</robot>
